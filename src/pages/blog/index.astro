---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = Array.from(new Set(posts.flatMap(post => post.data.tags || [])));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="grow">
			<div class="max-w-3xl mx-auto px-6 py-32">
				<header class="mb-16">
					<h1 class="text-4xl font-bold tracking-tight mb-4">所有文章</h1>
					<p class="text-black/40 mb-8">探索 AI 的本质，回归第一性原理。</p>
					
					<div class="flex flex-wrap gap-3" id="tag-filters">
						<button
							data-tag="all"
							class="tag-btn px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all bg-black text-white"
						>
							全部
						</button>
						{allTags.map(tag => (
							<button
								data-tag={tag}
								class="tag-btn px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all bg-black/5 text-black/40 hover:bg-black/10"
							>
								{tag}
							</button>
						))}
					</div>
				</header>

				<div class="space-y-20" id="post-list">
					{posts.map((post) => (
						<article class="group post-item" data-tags={(post.data.tags || []).join(',')}>
							<a href={`/blog/${post.id}/`} class="block space-y-4">
								<div class="flex items-center flex-wrap gap-4 text-xs font-bold uppercase tracking-widest text-black/30">
									<span><FormattedDate date={post.data.pubDate} /></span>
									{(post.data.tags || []).map(tag => (
										<span class="px-2 py-0.5 bg-black/5 rounded text-[10px] text-black/40">
											#{tag}
										</span>
									))}
								</div>
								<h2 class="text-3xl font-bold group-hover:text-black/60 transition-colors">
									{post.data.title}
								</h2>
								<p class="text-lg text-black/50 leading-relaxed">
									{post.data.description}
								</p>
								<div class="pt-2">
									<span class="text-sm font-bold border-b border-black/10 group-hover:border-black transition-all">
										阅读全文
									</span>
								</div>
							</a>
						</article>
					))}
				</div>
			</div>
		</main>
		<Footer />

		<script>
			const tagBtns = document.querySelectorAll('.tag-btn');
			const postItems = document.querySelectorAll('.post-item');

			tagBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					// Update buttons
					tagBtns.forEach(b => {
						b.classList.remove('bg-black', 'text-white');
						b.classList.add('bg-black/5', 'text-black/40');
					});
					btn.classList.add('bg-black', 'text-white');
					btn.classList.remove('bg-black/5', 'text-black/40');

					const selectedTag = btn.getAttribute('data-tag');

					// Update posts
					postItems.forEach(item => {
						if (selectedTag === 'all') {
							(item as HTMLElement).style.display = 'block';
						} else {
							const tags = item.getAttribute('data-tags')?.split(',') || [];
							if (selectedTag && tags.includes(selectedTag)) {
								(item as HTMLElement).style.display = 'block';
							} else {
								(item as HTMLElement).style.display = 'none';
							}
						}
					});
				});
			});
		</script>
	</body>
</html>
